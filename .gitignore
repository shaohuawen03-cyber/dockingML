!em.mdp
!nvt.mdp
!npt.mdp
!md.mdp

# ===== AmberTools/acpype 中间文件 =====
BEN.acpype/ANTECHAMBER_*
BEN.acpype/ATOMTYPE.INF
BEN.acpype/sqm.*
BEN.acpype/leap.log
BEN.acpype/acpype.log
BEN.acpype/*.frcmod
BEN.acpype/*.inpcrd
BEN.acpype/*.prmtop
BEN.acpype/*.lib
BEN.acpype/*.pkl

# ===== Python =====
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
*.egg-info/

# ===== 编辑器 =====
.vscode/
.idea/
*.swp
.DS_Store

