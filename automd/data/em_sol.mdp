; Energy-minimization mdp (steep + cg), modern GROMACS
integrator      = steep
emtol           = 1000.0     ; kJ/(mol·nm) -- tighter than old default
emstep          = 0.01
nsteps          = 50000
cutoff-scheme   = Verlet
nstlist         = 20
ns_type         = grid
rlist           = 1.0
coulombtype     = PME
rcoulomb        = 1.0
rvdw            = 1.0
pme_order       = 4
fourierspacing  = 0.12
constraints     = h-bonds
