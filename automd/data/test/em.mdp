; Energy minimization - test mode (short)
; For both single protein and complex
integrator               = steep
emtol                    = 1000.0
nsteps                   = 5000
nstenergy                = 10
nstlog                   = 10
nstxout                  = 100
nstvout                  = 100
cutoff-scheme            = Verlet
coulombtype              = PME
rcoulomb                 = 1.0
rvdw                     = 1.0
pbc                      = xyz
